      "onBeforePrint": "",
      "onAfterPrint": "Definir Data EDatIni;\nDefinir Data EDatFim;\nDefinir Alfa lData;\nDefinir Alfa lStrSQL;\nDefinir Alfa xWhere;\nDefinir Alfa str_numemp;\nDefinir Alfa str_codfil;\nDefinir Alfa str_codman;\n\nFTotReu = 0;\n\n/* ---------------------------------------------------\n   CONTAR O TOTAL DE REUNIÕES DO MANDATO NESTE PERIODO\n   --------------------------------------------------- */\n\n/* Converte as datas de entrada */\nConverteDataToDB(EDatIni, lData);\nlStrSQL = \" AND R100REU.DATREU >= \" + lData;\n\nConverteDataToDB(EDatFim, lData);\nlStrSQL = lStrSQL + \" AND R100REU.DATREU <= \" + lData;\n\n/* Filial e Mandato que estão sendo apresentados */\nlNumEmp = EmpAtu;\nlCodFil = R100REU.CODFIL;\nlCodMan = R100REU.CODMAN;\n\nIntParaAlfa(lNumEmp, str_numemp);\nIntParaAlfa(lCodFil, str_codfil);\nIntParaAlfa(lCodMan, str_codman);\n\nxWhere = \"R100REU.SITREU = 'R' AND R100REU.NUMEMP = \" + str_numemp + \" AND R100REU.CODFIL = \" + str_codfil;\n\nSe (ETipReu = 'O')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'O' \";\nSenao Se (ETipReu = 'E')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'E' \";\nSenao Se (ETipReu = 'D')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'D' \";\nSenao Se (ETipReu = 'I')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'I' \";\nSenao Se (ETipReu = 'L')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'L' \";\nSenao Se (ETipReu = 'P')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'P' \";\nSenao Se (ETipReu = 'S')\n  xWhere = xWhere + \" AND R100REU.TIPREU = 'S' \";       \n\nxWhere = xWhere + \" AND R100REU.CODMAN = \" + str_codman + lStrSQL;\n\n/* Retorna o total de registros */\nContador(\"R100REU\", xWhere, FTotReu);",
