  ],
  "orientation": "Portrait",
  "reportType": 0,
  "formatReport": 0,
  "sections": {
    "preambleSelect": "Definir Data EDatIni;\nDefinir Data EDatFim;\nDefinir Alfa lStrSQL;\nDefinir Alfa lData;\nDefinir Alfa lStrEmp;\n\nEDatFim = EDatRef;\n\nFDatIni = EDatIni;\nFDatFim = EDatFim;\n\nIntParaAlfa (EmpAtu, lStrEmp);\n\n/* ------------------------------------------------------------------\n   RETIRA ALGUNS CAMPOS DO SELECT PARA QUE POSSA SER FEITO O GROUP BY \n   ------------------------------------------------------------------ */\nDeleteFieldSQL (\"Detalhe_R100REU\", \"R100REP.DATREU\");\nDeleteFieldSQL (\"Detalhe_R100REU\", \"R100REP.HORREU\");\n\nDeleteFieldSQL (\"Detalhe_R100REU\", \"R100REU.DATREU\");\nDeleteFieldSQL (\"Detalhe_R100REU\", \"R100REU.HORREU\");\n\nDeleteFieldSQL (\"Detalhe_R100REU\", \"R100MAN.DATINI\");\nDeleteFieldSQL (\"Detalhe_R100REU\", \"R100MAN.DATFIM\");\n\n/* -----------------------------------------\n   GERA O FILTRO PARA AS REUNIOES DO PERIODO \n   ----------------------------------------- */\nConverteDataToDB(EDatIni, lData);\nlStrSQL = \"R100REU.DATREU >= \" + lData;\n\nConverteDataToDB(EDatFim, lData);\nlStrSQL = lStrSQL + \" AND R100REU.DATREU <= \" + lData + \" AND R100REU.SITREU = 'R' AND R100REU.NUMEMP = \" + lStrEmp;\n\nSe (ETipReu = 'O')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'O' \";\nSenao Se (ETipReu = 'E')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'E' \";\nSenao Se (ETipReu = 'D')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'D' \";\nSenao Se (ETipReu = 'I')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'I' \";\nSenao Se (ETipReu = 'L')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'L' \";\nSenao Se (ETipReu = 'P')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'P' \";\nSenao Se (ETipReu = 'S')\n  lStrSQL = lStrSQL + \" AND R100REU.TIPREU = 'S' \";   \n\n/* --------------------------------------\n   INCLUI CAMPO PARA CONTAGEM DE REUNIOES \n   -------------------------------------- */\nInsClauSQLCampoDireto (\"Detalhe_R100REU\", \"COUNT (*) QTDREU\");\n\n/* ----------------------------\n    INCLUI O PERIODO NO SELECT\n   ---------------------------- */\nInsClauSQLWhere (\"Detalhe_R100REU\", lStrSQL);\n\n\n/* --------------------------------------------------------------\n    INCLUI O GROUP BY PARA APRESENTAÇAO. \n    DEVE-SE TER MUITA ATENÇÃO COM OS CAMPOS INCLUIDOS NO MODELO.\n   -------------------------------------------------------------- */\nlStrSQL = \"R100REP.TIPCOL, R100REP.NUMCAD, R034FUN.NOMFUN, R100MEB.MOTSAI, R100REP.NUMEMP, R100REP.CODFIL, \\\n           R100REP.CIPTPR, R100REP.CODMAN, R100MEB.NUMEMP, R100MEB.CODFIL, \\\n           R100MEB.CODMAN, R100MEB.SEQELE, R100MEB.TIPCOL, R100MEB.NUMCAD, R100MEB.FUNMEB, R100REU.NUMEMP, \\\n           R100REU.CODFIL, R100REU.CODMAN, R034FUN.NUMEMP, R034FUN.TIPCOL, R034FUN.NUMCAD\";\n\nInsClauSQLGroupBy (\"Detalhe_R100REU\", lStrSQL);\n\n\nSe (ETipQue = 'F')\n  AlteraControle (\"Subtitulo_Filial\", \"Salto Página\", \"Sim\");\n\n\nSe (ETipQue = 'M')\n  {\n  AlteraControle (\"Subtitulo_Filial\", \"Salto Página\", \"Sim\");\n  AlteraControle (\"Subtitulo_Mandato\", \"Salto Página\", \"Sim\");\n  }",
    "selection": "/* S E L E Ç Ã O */\nDefinir Alfa lCodSit;\nDefinir Alfa lDesSit;\nDefinir Alfa LNomFun;\nDefinir Alfa xFuncao;\nDefinir Numero xFunMeb;\nDefinir Numero lQtdReu;\n\nSe ((R100REP.NUMCAD <> FNumCad) ou (R100REP.TIPCOL <> FTipCol))\n  {\n  Se (FNumCad <> 0)\n    ListaSecao (\"Adicional_MEB\");\n\n  FNumCad = R100REP.NUMCAD;\n  FTipCol = R100REP.TIPCOL;\n  FPresen = 0;\n  FFalInj = 0;\n  FFalJus = 0;\n  }\n\n/* ------------------------------------------------ \n   Quantidade de presenças, faltas e justificativas \n   ------------------------------------------------ */\nRetornaCampoNumero (\"Detalhe_R100REU\", \"QtdReu\", lQtdReu); \n\nSe (R100REP.CIPTPR = \"P\")\n  FPresen = lQtdReu;\n\nSe (R100REP.CIPTPR = \"F\")\n  FFalInj = lQtdReu;\n\nSe (R100REP.CIPTPR = \"J\")\n  FFalJus = lQtdReu;\n\nFNumCad = R100REP.NUMCAD;\nFTipCol = R100REP.TIPCOL;\n\nlNomFun = R034FUN.NOMFUN;\nAlteraControle (\"DNomFun\", \"Descrição\", lNomFun);\n\nxFunMeb = R100MEB.FunMeb;\nIntParaAlfa (xFunMeb, xFuncao);\nDescItemLista(\"LCipFme\", xFuncao, xFuncao);\nAlteraControle (\"DListaFuncao\", \"Descrição\", xFuncao);\n\n\n/* -------------------------- \n   Situção do membro da CIPA. \n   -------------------------- */\nlMotSai = R100MEB.MOTSAI;\nIntParaAlfa (lMotSai, lCodSit);\n\nSe (R100MEB.MOTSAI = 0)\n  lDesSit = \"Ativo\";\nSenao\n  DescItemLista(\"LCipMex\", lCodSit, lDesSit);\n\nAlteraControle (\"DDesMot\", \"Descrição\", lDesSit);",
    "initialization": "",
    "finalization": "",
    "functionRule": "",
    "printPage": ""
  },
