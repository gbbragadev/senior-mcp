    {
      "name": "Subtitulo_Conta",
      "bandType": "TITULO",
      "tag": 102,
      "position": {
        "top": 182,
        "left": 0,
        "width": 6000,
        "height": 24
      },
      "canPrint": true,
      "tableList": [
        "E045PLA.CTARED",
        "E070EMP.CODMPC",
        "E070EMP.CODEMP",
        "E070FIL.CODFIL",
        "E045PLA.CLACTA",
        "E045PLA.NIVCTA"
      ],
      "onBeforePrint": "Definir Alfa VMask01[20];        /* Mascara do plano de conta para nivel 1 */\nDefinir Alfa VMask02[20];        /* Mascara do plano de conta para nivel 2 */\nDefinir Alfa VMask03[20];        /* Mascara do plano de conta para nivel 3 */\nDefinir Alfa VMask04[20];        /* Mascara do plano de conta para nivel 4 */\nDefinir Alfa VMask05[20];        /* Mascara do plano de conta para nivel 5 */\nDefinir Alfa VMask06[20];        /* Mascara do plano de conta para nivel 6 */\nDefinir Alfa VMask07[20];        /* Mascara do plano de conta para nivel 7 */\nDefinir Alfa VMask08[20];        /* Mascara do plano de conta para nivel 8 */\nDefinir Alfa VMask09[20];        /* Mascara do plano de conta para nivel 9 */\nDefinir Alfa VMask10[20];        /* Mascara do plano de conta para nivel 10 */\nDefinir Alfa VMask11[20];        /* Mascara do plano de conta para nivel 11 */\nDefinir Alfa VMask12[20];        /* Mascara do plano de conta para nivel 12 */\nDefinir Alfa VMask13[20];        /* Mascara do plano de conta para nivel 13 */\nDefinir Alfa VMask14[20];        /* Mascara do plano de conta para nivel 14 */\nDefinir Alfa VMask15[20];        /* Mascara do plano de conta para nivel 15 */\n\n\nDefinir Alfa ECodFil;\n\nvCtaRed = E045Pla.CtaRed;\n\n/* Se a conta está zerada, nenhum movimento foi selecionado */\nSe  (vCtaRed = 0)\n    Cancel(1); \n\n/* Busca máscara para as contas (somente uma vez) */\nse (vPrimeiraVez = 1)\n   inicio\n   vPrimeiraVez = 0;\n   vCodMpc = E070EMp.CodMpc;\n   BuscaMascModPlano(vCodMpc,vMask01,vMask02,vMask03,vMask04,vMask05,vMask06,vMask07,vMask08,vMask09);\n   BuscaMascModPlano15n(vCodMpc,vMask10,vMask11,vMask12,vMask13,vMask14,vMask15);\n   fim;\n\n/* busca o saldo anterior */\nFSalAnt = 0;\nSe   (vOrdenacao = \"Consolidado\")\n     BuscaSaldoAnteriorAbr(ECodEmp,ECodFil,vCtaRed,EDatIni,FSalAnt);\nsenao\n     inicio\n     vCodEmp = E070Emp.CodEmp;\n     vCodFil = E070Fil.CodFil;\n     BuscaSaldoAnterior(vCodEmp,vCodFil,vCtaRed,EDatIni,FSalAnt);\n     fim;\n\n    \nFSalCta = FSalAnt;\n\n/* inicializa totalizadores */\nFTotDeb = 0;\nFTotCre = 0;\nFTotSal = 0;\n\n",
      "onAfterPrint": "",
