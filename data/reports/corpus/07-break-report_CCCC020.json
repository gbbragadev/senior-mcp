        "E640LCT.VLRLCT",
        "E640LCT.NUMLCT"
      ],
      "onBeforePrint": "Definir Cursor Cur_E640RAT;\nDefinir Alfa VCodCcu;\n\nvCtaAtu = E045Pla.CtaRed;\nvCtaDeb = E640Lct.CtaDeb;\nvCtaCre = E640Lct.CtaCre;\nVVlrLct = E640Lct.VlrLct;\nVNumLct = E640LCT.NumLct;\nVCodEmp = ECodEmp;\nFVlrCre = 0;\nFVlrDeb = 0;\nVCodCcu = \"\";\n\n\n\nse (VCtaAtu = VCtaDeb)\n    VNumCta = VCtaDeb;\nsenao\n    VNumCta = VCtaCre;\n\nCur_E640RAT.Sql \"Select CodCcu, VlrRat from E640RAT \\\n                 where  CodEmp = :VCodEmp \\\n                 and    NumLct = :VNumLct \\\n                 and    CtaRed = :VNumCta\";\n\nCur_E640RAT.AbrirCursor();\nenquanto(Cur_E640RAT.Achou)\ninicio\n    VCodCcu = Cur_E640RAT.CodCcu; \n    Se (vCtaAtu = vCtaDeb) \n    inicio\n        FCtaPar = vCtaCre;             @ contra-partida @\n        FVlrDeb = Cur_E640RAT.VlrRat;\n        FSalCta = FSalCta + FVlrDeb;   @ saldo atual com os débitos @ \n        /* totalizadores */\n        FTotDeb = FTotDeb + FVlrDeb;\n    fim;\n    senao\n    inicio\n        Se (vCtaAtu = vCtaCre)\n        inicio\n            FCtaPar = vCtaDeb;             @ contra-partida @\n            FVlrCre = Cur_E640RAT.VlrRat;\n            FSalCta = FSalCta - FVlrCre;   @ saldo atual com os créditos @ \n            /* totalizadores */\n            FTotCre = FTotCre + FVlrCre;\n        fim;\n    fim; \n    ListaSecao(\"Adicional_Rateio\"); \n    PrimeiraVez = 1;\n    Cur_E640RAT.Proximo();\nfim;\nCur_E640RAT.FecharCursor();\nse (VCodCcu <> \"\")\n    PrimeiraVez = 0;\nsenao\ninicio\n    Se (vCtaAtu = vCtaDeb) \n    inicio\n        FCtaPar = vCtaCre;             @ contra-partida @\n        FVlrDeb = FVlrDeb + vVlrLct;\n        FSalCta = FSalCta + VVlrLct;   @ saldo atual com os débitos @ \n        /* totalizadores */\n        FTotDeb = FTotDeb + vVlrLct;\n    fim;\n    senao\n    inicio \n        Se (vCtaAtu = vCtaCre)\n        inicio\n            FCtaPar = vCtaDeb;             @ contra-partida @\n            FVlrCre = FVlrCre + vVlrLct;\n            FSalCta = FSalCta - VVlrLct;   @ saldo atual com os créditos @ \n            /* totalizadores */\n            FTotCre = FTotCre + vVlrLct;\n        fim;\n    fim;\n    PrimeiraVez = 0;\n    ListaSecao(\"Adicional_Rateio\"); \nfim;\n\n",
      "onAfterPrint": "ContaAnterior = E045Pla.CtaRed;\n\n",
