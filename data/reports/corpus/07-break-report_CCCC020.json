        {
          "type": "TSDescricao",
          "name": "DescClassificacao",
          "position": {
            "top": 3,
            "left": 120,
            "width": 175,
            "height": 15
          },
          "caption": "DescClassificacao",
          "onPrint": "Definir Alfa vMask01;\nDefinir Alfa vMask02;\nDefinir Alfa vMask03;\nDefinir Alfa vMask04;\nDefinir Alfa vMask05;\nDefinir Alfa vMask06;\nDefinir Alfa vMask07;\nDefinir Alfa vMask08;\nDefinir Alfa vMask09;\nDefinir Alfa vMask10;\nDefinir Alfa vMask11;\nDefinir Alfa vMask12;\nDefinir Alfa vMask13;\nDefinir Alfa vMask14;\nDefinir Alfa vMask15;\nDefinir Alfa vMaskGen;\nDefinir Alfa vPlaCta;\nDefinir Alfa vValorStr;\nDefinir Numero vNivel;\nDefinir Alfa xClaCta;\nse (vPrimeiraVez = 0)\n   inicio\n   vPrimeiraVez = 1;\n   vCodMpc = E070Emp.CodMpc;\n   BuscaMascModPlano(vCodMpc,vMask01,vMask02,vMask03,vMask04,vMask05,vMask06,vMask07,vMask08,vMask09);\n   BuscaMascModPlano15n(vCodMpc,vMask10,vMask11,vMask12,vMask13,vMask14,vMask15);\n   fim;\n\nvPlaCta = E045PLA.ClaCta;\nvNivel = E045PLA.NivCta;\nvMaskGen = \" \";\nvValorStr = \" \";\nxClaCta = \" \";\n\nLerPosicaoStr(vPlaCta,vRetorno,1);\nxClaCta = vPlaCta;\nCopiarAlfa(xClaCta,1,1); @ Copiando a primeira posição da classificaçao da conta @\n\nse (xClaCta = \"1\")\n   vMaskGen = vMask01;\nsenao\n   se (xClaCta = \"2\")\n      vMaskGen = vMask02;\n   senao\n      se (xClaCta = \"3\")\n         vMaskGen = vMask03;\n      senao\n         se (xClaCta = \"4\")\n            vMaskGen = vMask04;\n         senao\n            se (xClaCta = \"5\")\n               vMaskGen = vMask05;\n            senao\n               se (xClaCta = \"6\")\n                  vMaskGen = vMask06;\n               senao\n                  se (xClaCta = \"7\")\n                     vMaskGen = vMask07;\n                  senao\n                     se (xClaCta = \"8\")\n                        vMaskGen = vMask08;\n                     senao\n                        se (xClaCta = \"9\")\n                          vMaskGen = vMask09;\n                        senao  \n                           se (xClaCta = \"10\")\n                              vMaskGen = vMask10;\n                           senao\n                              se (xClaCta = \"11\")\n                                 vMaskGen = vMask11;\n                              senao\n                                 se (xClaCta = \"12\")\n                                    vMaskGen = vMask12;\n                                 senao\n                                    se (xClaCta = \"13\")\n                                       vMaskGen = vMask13;\n                                    senao\n                                       se (xClaCta = \"14\")\n                                          vMaskGen = vMask14;\n                                       senao\n                                          se (xClaCta = \"15\")\n                                             vMaskGen = vMask15;\nse (vMaskGen = \" \")\n    Cancel(1);\nsenao\n    ConverteMaskContab(vNivel,vPlaCta,vMaskGen, vValorStr);\n\nValStr = vVaLorStr;\nCancel(2);",
