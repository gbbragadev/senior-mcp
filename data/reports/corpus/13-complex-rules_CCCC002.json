  "reportType": 0,
  "formatReport": 1,
  "sections": {
    "preambleSelect": "/*********** Definição de Variáveis ***********/\nDefinir Cursor Cur_E031Moe;\nDefinir Cursor Cur_E070Fil;\nDefinir Alfa vCodEmpAlfa;\nDefinir Alfa vNivCtaAlfa;\nDefinir Alfa vDefGruAlfa;\nDefinir Alfa vCond;\nDefinir Alfa vDesMoe;\nDefinir Alfa vCodMoe;\nDefinir Data vDatRef;\nDefinir Alfa vNumCgcAlfa;\n\nDefinir Alfa ECodFil;\nDefinir Alfa ECodMoe;\nDefinir Numero vQtdRegistros; \nDefinir Numero Res;\n\n/*********** Inicializações ***********/\nFNumPag = ENumFol;\nFNumLiv = ENumLiv;\nEQtdMax--;\n\nFCodFil = 0;\nvNivelAnterior = 0;\nFSaldoAnt = 0;\nFSalMes = 0;\nFDebMes = 0;\nFCreMes = 0;\n\nSe (ECodMoe <> \"\")\n   Inicio\n   AlteraControle(\"DMoeda\",\"Imprimir\",\"Verdadeiro\");\n   AlteraControle(\"DesMoe\",\"Imprimir\",\"Verdadeiro\");\n   AlteraControle(\"DDatRef\",\"Imprimir\",\"Verdadeiro\");\n   AlteraControle(\"EDatRef\",\"Imprimir\",\"Verdadeiro\");\n   AlteraControle(\"DVlrCot\",\"Imprimir\",\"Verdadeiro\");\n   AlteraControle(\"EVlrCot\",\"Imprimir\",\"Verdadeiro\");\n\n   vCodMoe = ECodMoe;\n   Cur_E031Moe.Sql \"SELECT DESMOE FROM E031MOE WHERE CODMOE =:vCodMoe\";\n   Cur_E031Moe.AbrirCursor();\n\n   vDesMoe = \"\";\n   Se (Cur_E031Moe.Achou)\n      vDesMoe = Cur_E031Moe.DesMoe;\n   Senao\n      Inicio\n      Mensagem (Retorna,\"Código da Moeda inválido![&OK]\");\n      Cur_E031Moe.FecharCursor();\n      Cancel(1);\n      Fim;\n   Cur_E031Moe.FecharCursor();\n\n   AlteraControle(\"DesMoe\",\"Descrição\",vDesMoe);\n   Fim;\n\nMMCria();\nvDatRef = EDatRef;\nMMBuscaCotacaoMoeda(vCodMoe,vDatRef,0,vCotPre);\nMMLibera();\n\nAlfaParaInt(ECodFil, FCodFil);\nEDatFim=EDatIni;\nUltimoDia(EDatFim); \n\nSe (EConLct = 'S') {\n   ConsistirLctoAContabilizar(ECodEmp,ECodFil,EDatIni,EDatFim,\"\",vQtdRegistros);\n   Se (vQtdRegistros > 0) {\n      Res = Mensagem(Retorna, \"Existem lançamentos que não foram contabilizados no período informado! Deseja Continuar? [&Sim, &Não]\");\n      Se (Res > 0)\n         Cancel(1);\n   }\n}\n\nDesmontaData(EDatini,vDia,vMes,vAno);\nMontaData(01,01,vAno,xDatini);\nAtualizaSaldoContabilAbr(ECodEmp,ECodFil,xDatIni,EDatFim);\n\nCarregaSaldoContabilAbr(ECodEmp,ECodFil,EDatIni,EDatFim,1);      @ com saldo anterior @\n\nEVlrCot = vCotPre;\n\n/* Busca o CNPJ a ser exibido no relatório */ \nPosicaoAlfa(\",\",ECodFil,vPosAbr1);\nPosicaoAlfa(\"-\",ECodFil,vPosAbr2);\n\nvAbrangencia = 0;\nSe ((vPosAbr1 > 0) ou (vPosAbr2 > 0))\n   Inicio\n   vAbrangencia = 1;\n   AlteraControle(\"DescConsolidado\",\"Imprimir\",\"Verdadeiro\");\n   BuscarFilialMaiorRelevancia(ECodEmp, ECodFil, \"\", FCodFil);        \n   Fim;\n \nvNumCgc = 0;\nCur_E070Fil.Sql \"SELECT CODFIL, NUMCGC FROM E070FIL WHERE CODEMP = :ECodEmp AND CODFIL = :FCodFil\";\nCur_E070Fil.AbrirCursor();         \nSe (Cur_E070Fil.Achou) \n    vNumCgc = Cur_E070fil.NumCgc;             \nCur_E070Fil.FecharCursor();\n\nVNumCgcAlfa=\"\";\nSe (vNumCgc <> 0)\n     Convertemascara(1, vNumCgc, VNumCgcAlfa, \"99.999.999/9999-99\");\n/* Atribui o CNPJ localizado */     \nAlteraControle(\"DescCNPJ\",\"Descrição\",VNumCgcAlfa);   \n/*********** Condições SQL ***********/\n\nIntParaAlfa(ECodEmp,vCodEmpAlfa);\nIntParaAlfa(ENivCta,vNivCtaAlfa);\nvCond = \"(E045PLA.CODEMP=\" + vCodEmpAlfa + \") AND (E045PLA.NIVCTA <= \" + vNivCtaAlfa + \")\";\n\nSe (ESitCta = 'A')    \n   vCond = vCond + \" AND (E045PLA.SITCTA='A')\";\nSenao\n   Se (ESitCta = 'I')    \n      vCond = vCond + \" AND (E045PLA.SITCTA='I')\";\n\nSe (EAnaSin = 'N')    \n   vCond = vCond + \" AND (E045PLA.ANASIN='S')\";\n\nSe (EDefGru <> \"\")\n   Inicio\n   MontaAbrangencia(\"E045PLA.DEFGRU\",EDefGru,vDefGruAlfa);\n   vCond = vCond + \" AND \" + vDefGruAlfa;\n   Fim;\n\nInsClauSqlWhere(\"Detalhe_Contas\",vCond);",
    "selection": "",
    "initialization": "",
    "finalization": "",
    "functionRule": "",
    "printPage": ""
  },
