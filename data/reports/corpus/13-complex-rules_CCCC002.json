      "onBeforePrint": "Definir Alfa VClaAnterior;\nDefinir Alfa VClaAtual;\n\nvCtaRed = E045Pla.CtaRed;\nFDebMes = 0;\nFCreMes = 0;\nFSalMes = 0;\nSaldoCompleto(vCtaRed,FDebMes,FCreMes,FSalMes);\nSe ((FDebMes > 0) e (vCotPre > 0))\n     FDebMes = FDebMes/vCotPre;\nSe ((FCreMes > 0) e (vCotPre > 0))\n     FCreMes = FCreMes/vCotPre;\nSe ((FSalMes > 0) e (vCotPre > 0))\n     FSalMes = FSalMes/vCotPre;\nFSaldoAnt = (FSalMes - FDebMes + FCreMes);\n\n/* Conta sem movimento */\nSe  (ETipMov = 2) \n    inicio\n    Se  ((FDebMes = 0) e (FCreMes = 0)) \n        Cancel(1);\n    fim;\nsenao\nSe  (ETipMov = 3)\n    inicio\n    Se  ((FSaldoAnt = 0) e (FDebMes = 0) e (FCreMes = 0)) \n        Cancel(1); \n    fim;\n\n\n/* Salto página para grupo de contas */\nvSaltouPagina = 0;\n\nSe  (ESalPag = 'S')\n    inicio\n    Se  (vClaAnterior = \"\")\n        inicio\n        vClaAnterior = E045Pla.ClaCta;\n        CopiarStr(vClaAnterior,1,1);\n        fim;\n\n    /* verifica se tem espaço na página. Retorna Zero se tem */\n    ProximaPagina(\"Adicional_GrupoContas\",vProximaPagina);  \n\n    vClaAtual = E045Pla.ClaCta;\n    CopiarStr(vClaAtual,1,1);\n    Se  (vClaAtual <> vClaAnterior)\n        inicio\n        Se  (vProximaPagina = 0)\n            ListaSecao(\"Adicional_GrupoContas\");\n        vClaAnterior = vClaAtual;\n        vSaltouPagina = 1;\n        fim;\n    fim;\n\n/**** trata linha em branco para cada nível de conta ****/\nSe   (ESalLin = 'S')\n     inicio\n     Se   (vNivelAnterior = 0)\n          vNivelAnterior = E045Pla.NivCta; \n     senao\n          inicio\n          /* verifica se tem espaço na página. Retorna Zero se tem */\n          ProximaPagina(\"Adicional_LinhaBranco\",vProximaPagina);  \n\n          vNivelAtual = E045Pla.NivCta;\n          Se  (vNivelAtual <> vNivelAnterior)       \n              inicio\n              Se   ((vSaltouPagina = 0) e (vProximaPagina = 0))\n                   ListaSecao(\"Adicional_LinhaBranco\");\n              vNivelAnterior = vNivelAtual;\n              fim; \n          fim;\n     fim;\n\n",
