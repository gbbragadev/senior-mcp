    {
      "name": "Rodape_Titulo",
      "bandType": "ADICIONAL",
      "tag": 502,
      "position": {
        "top": 173,
        "left": 0,
        "width": 6000,
        "height": 19
      },
      "canPrint": false,
      "tableList": [],
      "onBeforePrint": "Definir Numero i;\nDefinir Numero xQtdeRegistros;\nDefinir Alfa xTipoEntidadeAnterior;\nDefinir Alfa xTipoRegistro;\n\nDefinir Alfa vPerCon;\nDefinir Alfa vPerIns;\nDefinir Alfa vPerAlt;\nDefinir Alfa vPerExc;\nDefinir Alfa vAltPer;\nDefinir Alfa vNomEnt;\nDefinir Alfa vTipoEnt;\nDefinir Alfa vNomPerfil;\nDefinir Alfa vNomMnu;\nDefinir Alfa vCabecalho;\nDefinir Alfa vDetalhe;\n\nPara (i = 0; i < xQtdeRegistros; i++)\nInicio\n  PosicionarPermissoes(i);\n  vPerCon = PermissaoConsultar;    \n  vPerIns = PermissaoInserir;        \n  vPerAlt = PermissaoAlterar;    \n  vPerExc = PermissaoExcluir;\n  vAltPer = PermissaoAlterarPermissoes;       \n  vNomEnt = NomeEntidade;\n  vTipoEnt = TipoEntidade;\n  vNomPerfil = PerfilEntidade;\n  vNomMnu = NomeMenu;\n      \n  se ((vTipoEnt <> xTipoEntidadeAnterior) E (usaAbrPerfil = \"Sim\")){\n    xTipoEntidadeAnterior = vTipoEnt;\n    \n    se ((usaAbrPerfil = \"Sim\") E (xTipoEntidadeAnterior = \"U\")) {\n      xTipoRegistro = \"Perfil\";\n    } senao {\n      xTipoRegistro = \"Simples\";\n    }\n  \n    concatena(\"Cabecalho\", \"_\", xTipoRegistro, vCabecalho);  \n    ListaSecao(vCabecalho);\n  }\n  \n  \n  \n  concatena(\"Detalhe\", \"_\", xTipoRegistro, vDetalhe);\n  \n  ListaSecao(vDetalhe);\n  \nFim;",
      "onAfterPrint": "",
      "children": []
    },
