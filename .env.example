# Server
MCP_HTTP_PORT=3100
MCP_HTTP_TOKEN=your-secret-token-here

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maxun
DB_USER=postgres
DB_PASSWORD=your-password

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-...

# Embedding config (optional)
# EMBEDDING_MODEL=voyage-4
# EMBEDDING_FALLBACK_MODELS=voyage-4-large,voyage-4-lite
# EMBEDDING_DIM=1024

# Docs indexing (optional)
# SENIOR_DOCS_CHUNKS_FILE=output/senior-docs/chunks/chunks.jsonl
# SENIOR_DOCS_CHUNKS_FILES=output/senior-docs/chunks/chunks.jsonl,output/senior-dev-docs/chunks/chunks.jsonl

# LSP indexing (optional)
# SENIOR_LSP_ROOT=/path/to/lsp/sources
# SENIOR_LSP_EXTRA_PATHS=/path/to/extra1,/path/to/extra2
# SENIOR_LSP_EXTENSIONS=.lsp,.prg,.src,.txt,.sql,.xml

# Features
MCP_ENABLE_KNOWLEDGE_TOOLS=true

# Logging
# LOG_LEVEL=info
