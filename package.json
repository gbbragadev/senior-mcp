{
  "name": "senior-mcp",
  "version": "1.2.0",
  "description": "MCP HTTP server for Senior HCM documentation semantic search",
  "author": "gbbragadev",
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npm run build && node dist/server.js",
    "knowledge:reindex": "node scripts/knowledge/reindex.cjs --domain all",
    "knowledge:reindex:full": "node scripts/knowledge/reindex.cjs --domain all --full",
    "knowledge:reindex:docs": "node scripts/knowledge/reindex.cjs --domain docs",
    "knowledge:reindex:docs:full": "node scripts/knowledge/reindex.cjs --domain docs --full",
    "knowledge:reindex:lsp": "node scripts/knowledge/reindex.cjs --domain lsp",
    "knowledge:reindex:lsp:full": "node scripts/knowledge/reindex.cjs --domain lsp --full",
    "knowledge:eval:build": "node scripts/knowledge/eval/build-golden.cjs",
    "knowledge:eval": "node scripts/knowledge/eval.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.9.0",
    "dotenv": "^16.0.0",
    "express": "^4.17.2",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "zod": "^3.25.62"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/node": "^22.7.9",
    "ts-node": "^10.4.0",
    "typescript": "^5.0.0"
  }
}
